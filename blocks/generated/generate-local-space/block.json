{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "roxyapi/generate-local-space",
	"title": "Local space astrology map - Directional planetary compass lines (Western Astrology)",
	"category": "roxyapi",
	"icon": "admin-customizer",
	"description": "Local space astrology map - Directional planetary compass lines",
	"keywords": [
		"western astrology",
		"roxyapi",
		"generate",
		"local"
	],
	"version": "1.0.0",
	"textdomain": "roxyapi",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"padding": true,
			"margin": true
		}
	},
	"attributes": {
		"date": {
			"type": "string",
			"default": ""
		},
		"time": {
			"type": "string",
			"default": ""
		},
		"latitude": {
			"type": "string",
			"default": ""
		},
		"longitude": {
			"type": "string",
			"default": ""
		},
		"timezone": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php"
}
