{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "roxyapi/calculate-aspects",
	"title": "Calculate planetary aspects - Aspect finder for any date and time (Western Astrology)",
	"category": "roxyapi",
	"icon": "admin-customizer",
	"description": "Calculate planetary aspects - Aspect finder for any date and time",
	"keywords": [
		"western astrology",
		"roxyapi",
		"calculate",
		"aspects"
	],
	"version": "1.0.0",
	"textdomain": "roxyapi",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"padding": true,
			"margin": true
		}
	},
	"attributes": {
		"date": {
			"type": "string",
			"default": ""
		},
		"time": {
			"type": "string",
			"default": ""
		},
		"timezone": {
			"type": "string",
			"default": ""
		},
		"planets": {
			"type": "string",
			"default": ""
		},
		"aspectTypes": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php"
}
