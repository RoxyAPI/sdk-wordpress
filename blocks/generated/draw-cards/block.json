{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "roxyapi/draw-cards",
	"title": "Draw random tarot cards with reproducible results (Tarot)",
	"category": "roxyapi",
	"icon": "heart",
	"description": "Draw random tarot cards with reproducible results",
	"keywords": [
		"tarot",
		"roxyapi",
		"draw",
		"cards"
	],
	"version": "1.0.0",
	"textdomain": "roxyapi",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"padding": true,
			"margin": true
		}
	},
	"attributes": {
		"count": {
			"type": "string",
			"default": ""
		},
		"seed": {
			"type": "string",
			"default": ""
		},
		"allowReversals": {
			"type": "string",
			"default": ""
		},
		"allowDuplicates": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php"
}
