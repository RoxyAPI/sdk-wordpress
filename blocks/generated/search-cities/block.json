{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "roxyapi/search-cities",
	"title": "Search cities worldwide - Geocoding autocomplete with coordinates and timezone (Location and Timezone)",
	"category": "roxyapi",
	"icon": "superhero",
	"description": "Search cities worldwide - Geocoding autocomplete with coordinates and timezone",
	"keywords": [
		"location and timezone",
		"roxyapi",
		"search",
		"cities"
	],
	"version": "1.0.0",
	"textdomain": "roxyapi",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"padding": true,
			"margin": true
		}
	},
	"attributes": {
		"q": {
			"type": "string",
			"default": ""
		},
		"limit": {
			"type": "string",
			"default": ""
		},
		"offset": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php"
}
