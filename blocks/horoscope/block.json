{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "roxyapi/horoscope",
  "title": "Horoscope",
  "category": "roxyapi",
  "icon": "star-filled",
  "description": "Daily, weekly, monthly, love, career, and Chinese horoscopes for any zodiac sign.",
  "keywords": ["horoscope", "astrology", "zodiac", "roxyapi"],
  "version": "1.0.0",
  "textdomain": "roxyapi",
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "color": { "background": true, "text": true },
    "spacing": { "padding": true, "margin": true },
    "typography": { "fontSize": true }
  },
  "attributes": {
    "sign": { "type": "string", "default": "aries" },
    "period": { "type": "string", "default": "daily" },
    "type": { "type": "string", "default": "general" },
    "date": { "type": "string", "default": "today" }
  },
  "usesContext": ["roxyapi/sign", "roxyapi/birthDate"],
  "render": "file:./render.php",
  "variations": "file:./variations.php",
  "editorScript": "file:./index.js",
  "viewStyle": "file:./style.css",
  "editorStyle": "file:./editor.css"
}
