{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "roxyapi/astrology-wrapper",
	"title": "Astrology Section",
	"category": "roxyapi",
	"icon": "screenoptions",
	"description": "Wrapper block that shares a default zodiac sign and birth date with every RoxyAPI block inside it via block context.",
	"keywords": ["astrology", "zodiac", "section", "roxyapi"],
	"version": "1.0.0",
	"textdomain": "roxyapi",
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"attributes": {
		"defaultSign":      { "type": "string", "default": "aries" },
		"defaultBirthDate": { "type": "string", "default": "" },
		"defaultLat":       { "type": "number" },
		"defaultLon":       { "type": "number" }
	},
	"providesContext": {
		"roxyapi/sign":      "defaultSign",
		"roxyapi/birthDate": "defaultBirthDate",
		"roxyapi/lat":       "defaultLat",
		"roxyapi/lon":       "defaultLon"
	},
	"render":       "file:./render.php",
	"editorScript": "file:./index.js"
}
